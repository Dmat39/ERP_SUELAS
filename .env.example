# Copia este archivo a los .env de cada app. Referencia central de variables.
#
# --- apps/api/.env ---
# Cadena de conexión a Postgres (coincide con docker-compose.yml → puerto 5433 en host)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/erp_suelas?schema=public"
# Secreto para firmar los JWT (cámbialo en producción)
JWT_SECRET="dev-secret-cambiar-en-produccion"
# Vigencia del token
JWT_EXPIRES_IN="8h"
# Puerto de la API
PORT=3001

# --- apps/web/.env ---
# URL de la API que consume el frontend (server y cliente)
NEXT_PUBLIC_API_URL="http://localhost:3001"
