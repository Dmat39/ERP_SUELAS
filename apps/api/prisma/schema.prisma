generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE — usuarios, empresa, contactos
// ==========================================

enum UserRole {
  ADMIN
  ALMACENERO
  VENDEDOR
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(VENDEDOR)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// Contacto unificado: puede ser cliente, proveedor, o ambos (patrón res.partner de Odoo)
model Contact {
  id         String   @id @default(uuid())
  name       String
  docType    String? // DNI, RUC
  docNumber  String?
  phone      String?
  email      String?
  address    String?
  isCustomer Boolean  @default(false)
  isSupplier Boolean  @default(false)
  createdAt  DateTime @default(now())

  purchaseOrders PurchaseOrder[]
  orders         Order[]
}

// ==========================================
// RAW MATERIALS — materia prima
// ==========================================

model RawMaterial {
  id          String   @id @default(uuid())
  name        String // ej: "Caucho SBR", "Pegamento PU"
  unit        String // kg, lt, unidad
  costPerUnit Decimal  @default(0) @db.Decimal(10, 2)
  minStock    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  stock              RawMaterialStock[]
  movements          RawMaterialMovement[]
  bomLines           BomLine[]
  purchaseOrderItems PurchaseOrderItem[]
}

model Warehouse {
  id   String @id @default(uuid())
  name String

  rawMaterialStock RawMaterialStock[]
  productStock     ProductStock[]
}

model RawMaterialStock {
  rawMaterialId String
  warehouseId   String
  quantity      Decimal @default(0) @db.Decimal(12, 3)

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  @@id([rawMaterialId, warehouseId])
  @@index([warehouseId])
}

enum RawMaterialMovementType {
  COMPRA
  CONSUMO
  AJUSTE
}

model RawMaterialMovement {
  id            String                  @id @default(uuid())
  rawMaterialId String
  warehouseId   String
  type          RawMaterialMovementType
  quantity      Decimal                 @db.Decimal(12, 3)
  referenceType String? // "purchase_order" | "production_order" | "manual"
  referenceId   String?
  createdAt     DateTime                @default(now())

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([rawMaterialId])
  @@index([createdAt])
}

// ==========================================
// INVENTORY — producto terminado (templates + variantes)
// ==========================================

model Category {
  id       String     @id @default(uuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  templates ProductTemplate[]
}

model ProductTemplate {
  id          String   @id @default(uuid())
  name        String // ej: "Suela Runner"
  description String?
  categoryId  String?
  basePrice   Decimal  @default(0) @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  category Category?        @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
}

// Atributo genérico (Talla, Color, etc.) — reutilizable para futuros productos
model Attribute {
  id     String           @id @default(uuid())
  name   String // ej: "Talla"
  values AttributeValue[]
}

model AttributeValue {
  id          String @id @default(uuid())
  attributeId String
  value       String // ej: "39"

  attribute         Attribute                 @relation(fields: [attributeId], references: [id])
  variantAttributes ProductVariantAttribute[]

  @@index([attributeId])
}

model ProductVariant {
  id            String   @id @default(uuid())
  templateId    String
  sku           String   @unique
  priceOverride Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  template   ProductTemplate           @relation(fields: [templateId], references: [id])
  attributes ProductVariantAttribute[]
  stock      ProductStock[]
  movements  StockMovement[]
  boms       Bom[]
  orderItems OrderItem[]

  @@index([templateId])
}

model ProductVariantAttribute {
  variantId        String
  attributeValueId String

  variant        ProductVariant @relation(fields: [variantId], references: [id])
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
}

model ProductStock {
  variantId   String
  warehouseId String
  quantity    Decimal @default(0) @db.Decimal(12, 3)

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@id([variantId, warehouseId])
  @@index([warehouseId])
}

enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

model StockMovement {
  id            String            @id @default(uuid())
  variantId     String
  warehouseId   String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  referenceType String? // "production_order" | "order" | "manual"
  referenceId   String?
  createdAt     DateTime          @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([createdAt])
}

// ==========================================
// PRODUCTION — BOM (recetas) + órdenes de producción
// ==========================================

model Bom {
  id        String @id @default(uuid())
  variantId String
  name      String // ej: "Receta Suela Runner Talla 39"

  variant          ProductVariant    @relation(fields: [variantId], references: [id])
  lines            BomLine[]
  productionOrders ProductionOrder[]

  @@index([variantId])
}

model BomLine {
  id            String  @id @default(uuid())
  bomId         String
  rawMaterialId String
  quantity      Decimal @db.Decimal(12, 3) // cantidad de MP por 1 unidad de producto

  bom         Bom         @relation(fields: [bomId], references: [id])
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([bomId])
  @@index([rawMaterialId])
}

enum ProductionStatus {
  PLANIFICADA
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

model ProductionOrder {
  id                String           @id @default(uuid())
  bomId             String
  quantityToProduce Decimal          @db.Decimal(12, 3)
  status            ProductionStatus @default(PLANIFICADA)
  createdAt         DateTime         @default(now())
  completedAt       DateTime?

  bom Bom @relation(fields: [bomId], references: [id])

  @@index([bomId])
  @@index([status])
}

// ==========================================
// PURCHASES — proveedores, compras de MP
// ==========================================

enum PurchaseOrderStatus {
  BORRADOR
  ENVIADA
  RECIBIDA
  CANCELADA
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  supplierId String
  status     PurchaseOrderStatus @default(BORRADOR)
  createdAt  DateTime            @default(now())
  receivedAt DateTime?

  supplier Contact             @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  rawMaterialId   String
  quantity        Decimal @db.Decimal(12, 3)
  unitCost        Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  rawMaterial   RawMaterial   @relation(fields: [rawMaterialId], references: [id])

  @@index([purchaseOrderId])
  @@index([rawMaterialId])
}

// ==========================================
// SALES — pedidos internos y del storefront
// ==========================================

enum OrderOrigin {
  INTERNO
  WEB
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  DESPACHADO
  ENTREGADO
  CANCELADO
}

model Order {
  id         String      @id @default(uuid())
  customerId String
  origin     OrderOrigin @default(INTERNO)
  status     OrderStatus @default(PENDIENTE)
  total      Decimal     @default(0) @db.Decimal(10, 2)
  createdAt  DateTime    @default(now())

  customer Contact     @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  invoice  Invoice?
  shipment Shipment?

  @@index([customerId])
  @@index([status])
  @@index([origin])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

// ==========================================
// INVOICING — comprobante interno (stub, sin SUNAT real aún)
// ==========================================

enum InvoiceType {
  BOLETA
  FACTURA
}

enum SunatStatus {
  NO_ENVIADO
  ACEPTADO
  RECHAZADO
  OBSERVADO
}

model Invoice {
  id          String      @id @default(uuid())
  orderId     String      @unique
  type        InvoiceType
  serie       String
  numero      Int
  sunatStatus SunatStatus @default(NO_ENVIADO)
  pdfUrl      String?
  createdAt   DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@unique([serie, numero])
}

// ==========================================
// LOGISTICS — despacho/entrega
// ==========================================

enum ShipmentStatus {
  PENDIENTE
  EN_RUTA
  ENTREGADO
}

model Shipment {
  id          String         @id @default(uuid())
  orderId     String         @unique
  status      ShipmentStatus @default(PENDIENTE)
  address     String
  deliveredAt DateTime?

  order Order @relation(fields: [orderId], references: [id])
}
